; Скопируйте рядом с indexer.exe как indexer.ini (CMake при сборке копирует этот пример автоматически)
; Ключи [Database] совместимы с проектом FinalDiplom (Host, Name, …) и с нижним регистром (host, dbname, …)

[Paths]
roots = C:/temp/index_test
extensions = txt,md,ini,csv

